rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // সবাই ছবি দেখতে পারবে (Public Read Access)
      allow read: if true;
      
      // শুধুমাত্র mixorasmartshop@gmail.com ছবি আপলোড বা ডিলিট করতে পারবে
      allow write: if request.auth != null && request.auth.token.email == 'mixorasmartshop@gmail.com';
    }
  }
}